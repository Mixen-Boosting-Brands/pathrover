AddHandler cgi-script .pl
Options ExecCGI FollowSymlinks
DirectoryIndex index.php index.html
<Files 403.shtml>
order allow,deny
allow from all
</Files>
Options +FollowSymLinks
RewriteEngine On
RewriteBase /

# RewriteCond %{HTTPS} !=on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# RewriteCond %{HTTP_HOST} !^www.path-rover.com$ [NC]
# RewriteRule ^(.*)$ https://www.path-rover.com/$1 [L,R=301]

# RewriteCond %{HTTP_HOST} ^domain\.mx
# RewriteRule ^(.*)$ http://staging.mixen.mx/$1 [R=301]

RewriteCond %{REQUEST_URI}  !(\.png|\.jpg|\.webp|\.gif|\.jpeg|\.zip|\.css|\.svg|\.js|\.pdf|\.ttf|\.otf|\.woff|\.woff2|\.mp4|\.ico)$
RewriteRule (.*) routes.php [QSA,L]
